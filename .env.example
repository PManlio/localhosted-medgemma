# Ollama Docker image version (tag on hub.docker.com/r/ollama/ollama/tags)
OLLAMA_VERSION=0.20.7

# Port exposed on the host
OLLAMA_PORT=11434

# Model pulled and preloaded at startup
# hf.co/ prefix tells Ollama to pull directly from HuggingFace Hub.
# Q4_K_M = good balance quality/size (2.4 GB circa).
OLLAMA_DEFAULT_MODEL=hf.co/unsloth/medgemma-4b-it-GGUF:Q4_K_M

# Multimodal models (medgemma, llava, etc.) crash with parallel > 1 due to a
# known GGML sched_reserve bug (use-after-free on shared compute buffers).
# Keep at 1 for any vision-capable model; raise only for text-only models.
OLLAMA_NUM_PARALLEL=1
